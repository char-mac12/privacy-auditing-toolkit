{
  "model": {
    "id": "gpt2",
    "model_id": "canary_experiments/trained_model",
    "device": "cuda",
    "max_sequence_length": 256,
    "batch_size": 8
  },
  "dataset": {
    "id": "saved-split",
    "data_dir": "canary_experiments/training_data",
    "member_file": "members.json",
    "non_member_file": "non_members.json"
  },
  "attack": {
    "id": "range-mia",
    "base_attack": "loss-based-mia",
    "sample_size": 3,
    "paraphrase_method": "word_replace",
    "num_masks": 1,
    "mask_model": "bert-base-uncased",
    "device": "cpu"
  },
  "reporter": {
    "id": "pdf",
    "output_dir": "reports/pdf"
  }
}